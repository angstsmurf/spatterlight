# Headless build + regression test for the Scarier Battle System port.
#
# Builds a small console harness (test/battle_test.cpp) that links the Scarier
# interpreter sources against the bundled sx* os-layer stubs (no Glk, links the
# system zlib) and runs it against the synthetic, fully deterministic game
# test/battle_test.taf.  The harness checks the combat math through the public
# battle API and exits non-zero on any mismatch.
#
# Usage:
#   make -f Makefile.headless test     # build and run the battle test
#   make -f Makefile.headless taf      # regenerate test/battle_test.taf
#   make -f Makefile.headless clean
#
# test/battle_test.taf is a hand-authored ADRIFT 4.0 file (see
# test/make_battle_taf.py) and contains no third-party game data, so it is safe
# to keep in the tree and to rebuild offline.

CXX     ?= clang++
CC      ?= clang
CXXFLAGS ?= -std=c++11 -O2 -w -I.
LDLIBS  ?= -lz

# Sanitizer flags for the `sanitize` target (TODO ground rule: "ASan/UBSan-clean
# is mandatory").  -fno-sanitize-recover makes any UBSan finding abort with a
# non-zero status so the target actually fails rather than just printing.
# LeakSanitizer is left off via detect_leaks=0: it is unavailable on
# macOS/arm64, and throw-path leaks are expected (and documented) under P2/P3.
SAN_FLAGS := -fsanitize=address,undefined -fno-omit-frame-pointer \
             -fno-sanitize-recover=all -g
SAN_ENV   := ASAN_OPTIONS=detect_leaks=0 UBSAN_OPTIONS=print_stacktrace=1
SAN_RAND_OBJ := test/a5_randomness_san.o

# Shared, seedable cross-platform RNG (erkyrath_random), used by the v5 engine
# so deterministic walkthroughs reproduce.  Compiled as C; it pulls in glk.h
# (for glui32) from cheapglk but otherwise has no Glk dependency at seed 1234.
COMMON  := ../common_utils
A5_RAND_OBJ := test/a5_randomness.o

# All interpreter sources, plus the os-layer stubs the battle harness needs.
# mapdraw.cpp is the engine-neutral map model/rasteriser scmap.cpp draws into.
SRC  := $(wildcard sc*.cpp) mapdraw.cpp
STUBS   := sxstubs.cpp sxglob.cpp sxutils.cpp
HARNESS := test/battle_test.cpp

TAF     := test/battle_test.taf
BIN     := test/battle_test_hl

# The precedence and bad-parent harnesses bring their own os-layer port, so they
# link SRC alone (no sx* stubs) and drive the real interpreter loop over their
# own synthetic tafs.
PREC_HARNESS := test/precedence_test.cpp
PREC_TAF     := test/precedence_test.taf
PREC_BIN     := test/precedence_test_hl

BADP_HARNESS := test/badparent_test.cpp
BADP_TAF     := test/badparent_test.taf
BADP_BIN     := test/badparent_test_hl

# The corrupt-game harness (P2) links SRC alone with its own minimal os-layer
# port and needs no game data -- it drives the public boundary with corrupt byte
# buffers and an in-stack scr_fatal to prove no abort() reaches the host.
CORRUPT_HARNESS := test/corrupt_test.cpp
CORRUPT_BIN     := test/corrupt_test_hl

# The quit-flow harness drives the runner's run_loop_halt exception path
# (mid-turn scr_restart_game / scr_quit_game) over the precedence .taf; links
# SRC alone with its own os-layer port, like the precedence/badparent harnesses.
QUIT_HARNESS := test/quit_test.cpp
QUIT_BIN     := test/quit_test_hl

# ADRIFT 5 (Phases 0-1): container + de-obfuscation + zlib inflate -> XML, then
# an in-situ XML DOM parser -> typed object model.  Self-contained at the
# "container edge" -- links no interpreter sources.
A5_SRC  := a5blorb.cpp a5deobf.cpp
A5_MODEL_SRC := a5blorb.cpp a5deobf.cpp a5xml.cpp a5model.cpp
A5_TEXT_SRC := a5blorb.cpp a5deobf.cpp a5xml.cpp a5model.cpp \
               a5state.cpp a5restr.cpp a5expr.cpp a5sexpr.cpp a5text.cpp a5parse.cpp
A5_RUN_SRC := a5blorb.cpp a5deobf.cpp a5xml.cpp a5model.cpp \
              a5state.cpp a5restr.cpp a5expr.cpp a5sexpr.cpp a5text.cpp a5parse.cpp \
              a5rand.cpp a5sb.cpp a5run_ref.cpp a5run_events.cpp \
              a5run_action.cpp a5run.cpp
A5_HDRS := a5blorb.h a5deobf.h a5xml.h a5model.h
A5_TEXT_HDRS := $(A5_HDRS) a5state.h a5restr.h a5expr.h a5sexpr.h a5text.h a5parse.h
A5_RUN_HDRS := $(A5_TEXT_HDRS) a5parse.h a5rand.h a5sb.h a5run.h a5run_internal.h
A5DUMP_HARNESS := test/a5dump.cpp
A5DUMP_BIN     := test/a5dump
A5MODEL_HARNESS := test/a5model_dump.cpp
A5MODEL_BIN     := test/a5model_dump
A5TEXT_HARNESS := test/a5text_dump.cpp
A5TEXT_BIN     := test/a5text_dump
A5RUN_HARNESS := test/a5run_dump.cpp
A5RUN_BIN     := test/a5run_dump
A5MAP_HARNESS := test/a5map_dump.cpp
A5MAP_BIN     := test/a5map_dump
SCMAP_HARNESS := test/scmap_dump.cpp
SCMAP_BIN     := test/scmap_dump
A5PARSE_HARNESS := test/a5parse_test.cpp
A5PARSE_BIN     := test/a5parse_test
A5DIS_HARNESS   := test/a5_disambig_test.cpp
A5DIS_BIN       := test/a5_disambig_test
A5WALK_HARNESS  := test/a5_walk_test.cpp
A5WALK_BIN      := test/a5_walk_test
A5OBJ_HARNESS   := test/a5_objects_test.cpp
A5OBJ_BIN       := test/a5_objects_test
A5SEXPR_HARNESS := test/a5sexpr_test.cpp
A5SEXPR_BIN     := test/a5sexpr_test
A5SAVE_HARNESS  := test/a5_save_test.cpp
A5SAVE_BIN      := test/a5_save_test

.PHONY: test sanitize taf clean scmap a5dump a5model a5text a5run a5map a5parsetest a5runtest a5walkthroughs a5distest a5walktest a5objtest a5savetest a5sexprtest

# ADRIFT 5 game files live in an untracked (gitignored) folder under test/ so the
# harnesses can find them by a stable in-repo path; the games themselves are
# copyrighted and not committed.  Override A5_GAMES_DIR / A5_BULLETS to relocate.
# The a5runtest target skips gracefully when the file is absent.
A5_GAMES_DIR ?= test/adrift5-games
A5_BULLETS ?= $(A5_GAMES_DIR)/SixSilverBullets.blorb

test: $(BIN) $(TAF) $(PREC_BIN) $(PREC_TAF) $(BADP_BIN) $(BADP_TAF) $(CORRUPT_BIN) $(QUIT_BIN) $(A5PARSE_BIN) $(A5SEXPR_BIN) $(A5DIS_BIN) $(A5WALK_BIN) $(A5OBJ_BIN) $(A5SAVE_BIN)
	./$(BIN) $(TAF)
	./$(PREC_BIN) $(PREC_TAF)
	./$(BADP_BIN) $(BADP_TAF)
	./$(CORRUPT_BIN)
	./$(QUIT_BIN) $(PREC_TAF)
	./$(A5PARSE_BIN)
	./$(A5SEXPR_BIN)
	./$(A5DIS_BIN)
	./$(A5WALK_BIN)
	./$(A5OBJ_BIN)
	./$(A5SAVE_BIN)
	@$(MAKE) -f Makefile.headless a5runtest

# Golden-transcript regression for the ADRIFT 5 (P4) engine: replays
# test/a5_bullets_script.txt through Six Silver Bullets and diffs against
# test/a5_bullets_expected.txt.  Skips (does not fail) if the game file is
# missing, since it cannot be checked in.
a5runtest: $(A5RUN_BIN)
	@if [ -f "$(A5_BULLETS)" ]; then \
	  ./$(A5RUN_BIN) "$(A5_BULLETS)" test/a5_bullets_script.txt > /tmp/a5_bullets_got.txt 2>/dev/null; \
	  if diff -u test/a5_bullets_expected.txt /tmp/a5_bullets_got.txt; then \
	    echo "a5runtest: Six Silver Bullets transcript matches"; \
	  else \
	    echo "a5runtest: FAILED (transcript diverged)"; exit 1; \
	  fi; \
	else \
	  echo "a5runtest: SKIP (game file not found: $(A5_BULLETS))"; \
	fi

# Real-game walkthrough corpus: replays published walkthroughs for the games in
# $(A5_GAMES_DIR) through BOTH a5run_dump and FrankenDrift (test/a5_groundtruth.sh)
# and checks each transcript's divergence against its recorded baseline (see
# test/A5_WALKTHROUGH_FINDINGS.md).  Per-game SKIP when the (uncommittable) game
# file is absent; needs FrankenDrift.Headless built for the differential games
# (the golden-backed games, e.g. Achtung Panzer, need only a5run_dump).
# Not part of `test` (external data + dotnet).  Fails if any game regresses
# past its baseline hunk budget.
a5walkthroughs: $(A5RUN_BIN)
	@test/run_a5_walkthroughs.sh

# ASan/UBSan sweep of every self-contained, no-external-data harness that `test`
# runs (the a5runtest game-file replay is excluded: it needs uncommittable game
# data -- run it under sanitizers by hand with
#   make -f Makefile.headless a5runtest CXXFLAGS="$(CXXFLAGS) $(SAN_FLAGS)").
# Each harness is rebuilt from source into a *_san binary (so there is no
# timestamp/flag-staleness footgun) and run immediately; a sanitizer abort or a
# non-zero exit stops the target.
sanitize: $(TAF) $(PREC_TAF) $(BADP_TAF) $(SAN_RAND_OBJ)
	$(CXX) $(CXXFLAGS) $(SAN_FLAGS) $(SRC) $(STUBS) $(HARNESS) $(LDLIBS) -o $(BIN)_san
	$(SAN_ENV) ./$(BIN)_san $(TAF)
	$(CXX) $(CXXFLAGS) $(SAN_FLAGS) $(SRC) $(PREC_HARNESS) $(LDLIBS) -o $(PREC_BIN)_san
	$(SAN_ENV) ./$(PREC_BIN)_san $(PREC_TAF)
	$(CXX) $(CXXFLAGS) $(SAN_FLAGS) $(SRC) $(BADP_HARNESS) $(LDLIBS) -o $(BADP_BIN)_san
	$(SAN_ENV) ./$(BADP_BIN)_san $(BADP_TAF)
	$(CXX) $(CXXFLAGS) $(SAN_FLAGS) $(SRC) $(CORRUPT_HARNESS) $(LDLIBS) -o $(CORRUPT_BIN)_san
	$(SAN_ENV) ./$(CORRUPT_BIN)_san
	$(CXX) $(CXXFLAGS) $(SAN_FLAGS) $(SRC) $(QUIT_HARNESS) $(LDLIBS) -o $(QUIT_BIN)_san
	$(SAN_ENV) ./$(QUIT_BIN)_san $(PREC_TAF)
	$(CXX) $(CXXFLAGS) $(SAN_FLAGS) a5parse.cpp $(A5PARSE_HARNESS) -o $(A5PARSE_BIN)_san
	$(SAN_ENV) ./$(A5PARSE_BIN)_san
	$(CXX) $(CXXFLAGS) $(SAN_FLAGS) a5sexpr.cpp a5rand.cpp $(A5SEXPR_HARNESS) $(SAN_RAND_OBJ) $(LDLIBS) -o $(A5SEXPR_BIN)_san
	$(SAN_ENV) ./$(A5SEXPR_BIN)_san
	$(CXX) $(CXXFLAGS) $(SAN_FLAGS) $(A5_RUN_SRC) $(A5DIS_HARNESS) $(SAN_RAND_OBJ) $(LDLIBS) -o $(A5DIS_BIN)_san
	$(SAN_ENV) ./$(A5DIS_BIN)_san
	$(CXX) $(CXXFLAGS) $(SAN_FLAGS) $(A5_RUN_SRC) $(A5WALK_HARNESS) $(SAN_RAND_OBJ) $(LDLIBS) -o $(A5WALK_BIN)_san
	$(SAN_ENV) ./$(A5WALK_BIN)_san
	$(CXX) $(CXXFLAGS) $(SAN_FLAGS) $(A5_RUN_SRC) $(A5OBJ_HARNESS) $(SAN_RAND_OBJ) $(LDLIBS) -o $(A5OBJ_BIN)_san
	$(SAN_ENV) ./$(A5OBJ_BIN)_san
	$(CXX) $(CXXFLAGS) $(SAN_FLAGS) $(A5_RUN_SRC) $(A5SAVE_HARNESS) $(SAN_RAND_OBJ) $(LDLIBS) -o $(A5SAVE_BIN)_san
	$(SAN_ENV) ./$(A5SAVE_BIN)_san
	@echo "sanitize: all self-contained harnesses ASan/UBSan-clean"

# RNG object built with sanitizers, for the a5 run-pipeline sanitize builds.
$(SAN_RAND_OBJ): $(COMMON)/randomness.c $(COMMON)/randomness.h
	$(CC) -O2 -w -I../cheapglk $(SAN_FLAGS) -c -o $@ $(COMMON)/randomness.c

$(BIN): $(SRC) $(STUBS) $(HARNESS)
	$(CXX) $(CXXFLAGS) $(SRC) $(STUBS) $(HARNESS) $(LDLIBS) -o $@

$(PREC_BIN): $(SRC) $(PREC_HARNESS)
	$(CXX) $(CXXFLAGS) $(SRC) $(PREC_HARNESS) $(LDLIBS) -o $@

$(BADP_BIN): $(SRC) $(BADP_HARNESS)
	$(CXX) $(CXXFLAGS) $(SRC) $(BADP_HARNESS) $(LDLIBS) -o $@

$(CORRUPT_BIN): $(SRC) $(CORRUPT_HARNESS)
	$(CXX) $(CXXFLAGS) $(SRC) $(CORRUPT_HARNESS) $(LDLIBS) -o $@

$(QUIT_BIN): $(SRC) $(QUIT_HARNESS)
	$(CXX) $(CXXFLAGS) $(SRC) $(QUIT_HARNESS) $(LDLIBS) -o $@

# Build the ADRIFT 5 XML dumper.  Run it by hand on a game:
#   make -f Makefile.headless a5dump
#   ./test/a5dump path/to/game.blorb > game.xml
a5dump: $(A5DUMP_BIN)
$(A5DUMP_BIN): $(A5_SRC) $(A5DUMP_HARNESS) a5blorb.h a5deobf.h
	$(CXX) $(CXXFLAGS) $(A5_SRC) $(A5DUMP_HARNESS) $(LDLIBS) -o $@

# Build the ADRIFT 5 object-model dumper (Phase 1).  Run it by hand:
#   make -f Makefile.headless a5model
#   ./test/a5model_dump path/to/game.blorb
a5model: $(A5MODEL_BIN)
$(A5MODEL_BIN): $(A5_MODEL_SRC) $(A5MODEL_HARNESS) $(A5_HDRS)
	$(CXX) $(CXXFLAGS) $(A5_MODEL_SRC) $(A5MODEL_HARNESS) $(LDLIBS) -o $@

# Build the ADRIFT 5 text-engine harness (Phase 2).  Run it by hand:
#   make -f Makefile.headless a5text
#   ./test/a5text_dump path/to/game.blorb [LocationKey]
a5text: $(A5TEXT_BIN)
$(A5TEXT_BIN): $(A5_TEXT_SRC) $(A5TEXT_HARNESS) $(A5_TEXT_HDRS)
	$(CXX) $(CXXFLAGS) $(A5_TEXT_SRC) $(A5TEXT_HARNESS) $(LDLIBS) -o $@

# Build the ADRIFT 5 turn-loop harness (Phase 3).  Run it by hand:
#   make -f Makefile.headless a5run
#   ./test/a5run_dump path/to/game.blorb [script.txt]
a5run: $(A5RUN_BIN)
$(A5RUN_BIN): $(A5_RUN_SRC) $(A5RUN_HARNESS) $(A5_RUN_HDRS) $(A5_RAND_OBJ)
	$(CXX) $(CXXFLAGS) $(A5_RUN_SRC) $(A5RUN_HARNESS) $(A5_RAND_OBJ) $(LDLIBS) -o $@

# The shared erkyrath RNG, compiled as C with cheapglk on the include path
# (only for glui32 via glk.h).
$(A5_RAND_OBJ): $(COMMON)/randomness.c $(COMMON)/randomness.h
	$(CC) -O2 -w -I../cheapglk -c -o $@ $(COMMON)/randomness.c

# Render the ADRIFT 5 map headlessly to a PPM (no Glk).  Run it by hand:
#   make -f Makefile.headless a5map
#   ./test/a5map_dump path/to/game.blorb [script.txt] -o map.ppm [-all]
a5map: $(A5MAP_BIN)
$(A5MAP_BIN): $(A5_RUN_SRC) a5map.cpp mapdraw.cpp $(A5MAP_HARNESS) $(A5_RUN_HDRS) \
              a5map.h mapdraw.h $(A5_RAND_OBJ)
	$(CXX) $(CXXFLAGS) $(A5_RUN_SRC) a5map.cpp mapdraw.cpp $(A5MAP_HARNESS) \
	    $(A5_RAND_OBJ) $(LDLIBS) -o $@

# Render the ADRIFT 4 map headlessly to a PPM (no Glk).  Run it by hand:
#   make -f Makefile.headless scmap
#   ./test/scmap_dump path/to/game.taf [script.txt] -o map.ppm [-all] [-grid]
scmap: $(SCMAP_BIN)
$(SCMAP_BIN): $(SRC) $(SCMAP_HARNESS) scmap.h mapdraw.h
	$(CXX) $(CXXFLAGS) $(SRC) $(SCMAP_HARNESS) $(LDLIBS) -o $@

# Self-contained matcher regression test (no game data); part of `test`.
a5parsetest: $(A5PARSE_BIN)
	./$(A5PARSE_BIN)
$(A5PARSE_BIN): a5parse.cpp a5parse.h $(A5PARSE_HARNESS)
	$(CXX) $(CXXFLAGS) a5parse.cpp $(A5PARSE_HARNESS) -o $@

# Self-contained expression-evaluator regression (no game data); part of `test`.
# Exercises a5sexpr (the sole variable/expression evaluator since a5arith was
# folded in); links a5rand for its rand()/oneof() draws.
a5sexprtest: $(A5SEXPR_BIN)
	./$(A5SEXPR_BIN)
$(A5SEXPR_BIN): a5sexpr.cpp a5sexpr.h a5rand.cpp $(A5SEXPR_HARNESS) $(A5_RAND_OBJ)
	$(CXX) $(CXXFLAGS) a5sexpr.cpp a5rand.cpp $(A5SEXPR_HARNESS) $(A5_RAND_OBJ) $(LDLIBS) -o $@

# Self-contained disambiguation regression (synthetic in-memory v5 adventure,
# no game data); part of `test`.  Links the full a5 run pipeline.
a5distest: $(A5DIS_BIN)
	./$(A5DIS_BIN)
$(A5DIS_BIN): $(A5_RUN_SRC) $(A5DIS_HARNESS) $(A5_RUN_HDRS) $(A5_RAND_OBJ)
	$(CXX) $(CXXFLAGS) $(A5_RUN_SRC) $(A5DIS_HARNESS) $(A5_RAND_OBJ) $(LDLIBS) -o $@

# Self-contained walks + event sub-events regression (synthetic in-memory v5
# adventures, no game data); part of `test`.  Exercises clsWalk (steps,
# ShowEnterExit, ComesAcross, looping) and clsEvent.RunSubEvent
# (DisplayMessage gate + SetLook), which the shipped corpus does not cover.
a5walktest: $(A5WALK_BIN)
	./$(A5WALK_BIN)
$(A5WALK_BIN): $(A5_RUN_SRC) $(A5WALK_HARNESS) $(A5_RUN_HDRS) $(A5_RAND_OBJ)
	$(CXX) $(CXXFLAGS) $(A5_RUN_SRC) $(A5WALK_HARNESS) $(A5_RAND_OBJ) $(LDLIBS) -o $@

# Self-contained multiple-object reference regression (synthetic in-memory v5
# adventure, no game data); part of `test`.  Exercises the %objects% grammar
# (clsUserSession.InputMatchesObjects: "X and Y" / "all" / "all except Z" /
# plural nouns), the per-item action loop and the FailOverride, none of which the
# shipped corpus covers under the deterministic seed.
a5objtest: $(A5OBJ_BIN)
	./$(A5OBJ_BIN)
$(A5OBJ_BIN): $(A5_RUN_SRC) $(A5OBJ_HARNESS) $(A5_RUN_HDRS) $(A5_RAND_OBJ)
	$(CXX) $(CXXFLAGS) $(A5_RUN_SRC) $(A5OBJ_HARNESS) $(A5_RAND_OBJ) $(LDLIBS) -o $@

# Self-contained save/restore round-trip regression (synthetic in-memory v5
# adventure, no game data); part of `test`.  Proves a5run_save / a5run_restore
# capture object/variable/event/RNG/seen state for a byte-identical
# continuation after restore (Phase 5).
a5savetest: $(A5SAVE_BIN)
	./$(A5SAVE_BIN)
$(A5SAVE_BIN): $(A5_RUN_SRC) $(A5SAVE_HARNESS) $(A5_RUN_HDRS) $(A5_RAND_OBJ)
	$(CXX) $(CXXFLAGS) $(A5_RUN_SRC) $(A5SAVE_HARNESS) $(A5_RAND_OBJ) $(LDLIBS) -o $@

# The TAFs are checked in; these targets only refresh them from the generators.
taf: $(TAF) $(PREC_TAF) $(BADP_TAF)
$(TAF): test/make_battle_taf.py
	python3 test/make_battle_taf.py $(TAF)
$(PREC_TAF): test/make_precedence_taf.py
	python3 test/make_precedence_taf.py $(PREC_TAF)
$(BADP_TAF): test/make_badparent_taf.py
	python3 test/make_badparent_taf.py $(BADP_TAF)

clean:
	rm -f $(BIN) $(PREC_BIN) $(BADP_BIN) $(CORRUPT_BIN) $(QUIT_BIN) $(A5DUMP_BIN) $(A5MODEL_BIN) $(A5TEXT_BIN) $(A5RUN_BIN) $(A5PARSE_BIN) $(A5SEXPR_BIN) $(A5DIS_BIN) $(A5WALK_BIN) $(A5OBJ_BIN) $(A5SAVE_BIN) $(A5_RAND_OBJ)
	rm -f $(BIN)_san $(PREC_BIN)_san $(BADP_BIN)_san $(CORRUPT_BIN)_san $(QUIT_BIN)_san $(A5PARSE_BIN)_san $(A5SEXPR_BIN)_san $(A5DIS_BIN)_san $(A5WALK_BIN)_san $(A5OBJ_BIN)_san $(A5SAVE_BIN)_san $(SAN_RAND_OBJ)
