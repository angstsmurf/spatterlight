<asl version="580">
  <include ref="English.aslx" />
  <include ref="Core.aslx" />

  <game name="Command Test">
    <gameid>d0d0cafe-0000-0000-0000-000000000002</gameid>
    <author>Geas test suite</author>
  </game>

  <object name="lounge">
    <inherit name="editor_room" />
    <object name="player">
      <inherit name="editor_player" />
    </object>
    <object name="apple">
      <inherit name="editor_object" />
      <take />
    </object>
    <object name="chest">
      <inherit name="editor_object" />
      <inherit name="openable" />
    </object>
    <object name="tophat">
      <inherit name="editor_object" />
      <alias>hat</alias>
      <take />
    </object>
    <object name="strawhat">
      <inherit name="editor_object" />
      <alias>hat</alias>
      <take />
    </object>
    <exit alias="north" to="garden">
      <inherit name="northdirection" />
    </exit>
  </object>

  <object name="garden">
    <inherit name="editor_room" />
    <object name="rose">
      <inherit name="editor_object" />
    </object>
  </object>

  <!-- §3 input model: one command per engine-level prompt kind. -->
  <command name="typecmd">
    <pattern>type</pattern>
    <script><![CDATA[
      get input {
        msg ("You typed " + result)
      }
    ]]></script>
  </command>
  <command name="pickcmd">
    <pattern>pick</pattern>
    <script><![CDATA[
      options = Split("red;green;blue", ";")
      show menu ("Pick a colour", options, false) {
        msg ("You picked " + result)
      }
      on ready {
        msg ("menu settled")
      }
    ]]></script>
  </command>
  <command name="querycmd">
    <pattern>query</pattern>
    <script><![CDATA[
      ask ("Are you sure?") {
        if (result) {
          msg ("Confirmed")
        }
        else {
          msg ("Denied")
        }
      }
    ]]></script>
  </command>
  <command name="napcmd">
    <pattern>nap</pattern>
    <script><![CDATA[
      wait {
        msg ("You wake up.")
      }
    ]]></script>
  </command>
</asl>
